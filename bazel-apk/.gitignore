# The shared bundle producer, built by `./gradlew :bundle-producer:uberJar` and
# copied here for the `bundle_preview` rule. A build artifact, not source.
bundle-producer-all.jar

# Bundle outputs.
*.png
preview_bundle.png

# Bazel local build artifacts: convenience symlinks + the bzlmod lockfile.
# (The lockfile here can encode environment-specific registry resolution, so it
# isn't committed; CI resolves against the default registry.)
/bazel-*
MODULE.bazel.lock
